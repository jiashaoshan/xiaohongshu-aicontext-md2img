{
  "output": {
    "baseDir": "./output",
    "structure": {
      "formatted": "formatted",
      "card": "card",
      "redbookContext": "redbook_context.txt"
    }
  },
  "card": {
    "concurrentLimit": 8,
    "charsPerPage": 240,
    "maxRetries": 2,
    "timeoutMs": 60000,
    "batchDelayMs": 500
  },
  "xiaohongshu": {
    "contentMaxLength": 1000,
    "titleMaxLength": 20
  },
  "cover": {
    "template": "小红书封面卡片，纯白背景竖版2K(1440x2038)。【标题区-占70%顶部区域】：大标题【正红#E60012、粗宋体120px、加粗、居左】='{topic}'；下行副标题【灰色#666666、黑体48px】='{summary}'。【底部落款-固定40px高】：右侧显示【灰色小字：作者你的名字】+【字数XXX阅读约X分钟】。整体风格：极简纯净无装饰，标题醒目突出，底部落款固定",
    "size": "2K",
    "timeoutMs": 120000
  },
  "cardStyle": {
    "bgColor": "#ffffff",
    "highlightColor": "#E60012",
    "footerText": "字数 {count} | 阅读约 {minutes} 分钟",
    "lineHeight": 2.5,
    "fontSize": 28,
    "showFooter": true
  },
  "emoji": {
    "replacements": {
      "好": "👍好",
      "棒": "👏棒",
      "重要": "🔥重要",
      "注意": "⚠️注意",
      "推荐": "⭐推荐",
      "步骤": "✨步骤",
      "爱": "❤️爱",
      "笑": "😂笑"
    }
  },
  "deAiPatterns": {
    "remove": [
      "^(以下是|以下是关于|本文将|这篇文章将|让我们|值得注意的是|需要指出的是)",
      "众所周知|不可否认的是|必须承认的是"
    ],
    "replace": {
      "非常|十分|极其|特别": "",
      "众所周知|不可否认的是|必须承认的是": "说实话"
    },
    "markers": {
      "首先|其次|再次|最后": "👉",
      "总之|综上所述|总而言之": "👉"
    }
  },
  "titleFormulas": [
    "3分钟读懂{topic}",
    "{topic}|看完这篇就够了",
    "终于有人把{topic}讲清楚了",
    "{topic}?90%的人都理解错了",
    "关于{topic},没人告诉你的真相",
    "读完{topic},我悟了",
    "{topic}|改变我人生的3个观点"
  ],
  "hashtags": {
    "base": ["#干货分享", "#知识科普", "#必看", "#自我提升"]
  }
}
